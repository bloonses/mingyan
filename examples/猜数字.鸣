打印("=== 猜数字游戏 ===")
打印()

变量 目标 = 随机整数(1, 100)
变量 猜测次数 = 0
变量 最大次数 = 7

打印("我想了一个1到100之间的数字，你有" + 转字符串(最大次数) + "次机会来猜它！")
打印()

当 猜测次数 < 最大次数 {
    变量 输入内容 = 输入("请输入你的猜测: ")
    变量 猜测 = 转整数(输入内容)
    猜测次数 += 1

    如果 猜测 == 目标 {
        打印("🎉 恭喜你猜对了！数字就是 " + 转字符串(目标))
        打印("你用了 " + 转字符串(猜测次数) + " 次猜中！")
        返回
    } 否则如果 猜测 < 目标 {
        打印("太小了！还剩 " + 转字符串(最大次数 - 猜测次数) + " 次机会")
    } 否则 {
        打印("太大了！还剩 " + 转字符串(最大次数 - 猜测次数) + " 次机会")
    }
}

打印("😢 很遗憾，你没有猜中。数字是 " + 转字符串(目标))
