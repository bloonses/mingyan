变量 数据 = [64, 34, 25, 12, 22, 11, 90]
打印("原始数据: " + 转字符串(数据))
打印("冒泡排序: " + 转字符串(冒泡排序(数据)))

变量 有序 = 排序(数据)
打印("有序数据: " + 转字符串(有序))
打印("查找22的位置: " + 转字符串(二分查找(有序, 22)))
打印("查找100的位置: " + 转字符串(二分查找(有序, 100)))
