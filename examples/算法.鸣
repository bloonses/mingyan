函数 冒泡排序(列表) {
    变量 n = 长度(列表)
    遍历 i 在 范围(0, n) {
        遍历 j 在 范围(0, n - i - 1) {
            如果 列表[j] > 列表[j + 1] {
                变量 临时 = 列表[j]
                列表[j] = 列表[j + 1]
                列表[j + 1] = 临时
            }
        }
    }
    返回 列表
}

函数 二分查找(列表, 目标) {
    变量 左 = 0
    变量 右 = 长度(列表) - 1
    当 左 <= 右 {
        变量 中 = (左 + 右) / 2
        如果 列表[中] == 目标 {
            返回 中
        } 否则如果 列表[中] < 目标 {
            左 = 中 + 1
        } 否则 {
            右 = 中 - 1
        }
    }
    返回 -1
}

函数 快速排序(列表) {
    如果 长度(列表) <= 1 {
        返回 列表
    }
    变量 基准 = 列表[0]
    变量 左侧 = []
    变量 右侧 = []
    变量 等于 = [基准]
    遍历 i 在 范围(1, 长度(列表)) {
        如果 列表[i] < 基准 {
            追加(左侧, 列表[i])
        } 否则如果 列表[i] > 基准 {
            追加(右侧, 列表[i])
        } 否则 {
            追加(等于, 列表[i])
        }
    }
    返回 合并(快速排序(左侧), 合并(等于, 快速排序(右侧)))
}

函数 合并(列表a, 列表b) {
    变量 结果 = []
    追加(结果, 列表a)
    追加(结果, 列表b)
    返回 结果
}

