打印("=== 鸣言中文编程语言 示例 ===")
打印()

打印("--- 1. 变量与数据类型 ---")
变量 整数 = 42
变量 浮点数 = 3.14
变量 字符串 = "你好，世界！"
变量 布尔值 = 真
变量 空值 = 空
变量 列表 = [1, 2, 3, 4, 5]
变量 字典 = {"名字": "鸣言", "版本": 1.0, "语言": "中文"}

打印("整数: " + 转字符串(整数))
打印("浮点数: " + 转字符串(浮点数))
打印("字符串: " + 字符串)
打印("布尔值: " + 转字符串(布尔值))
打印("列表: " + 转字符串(列表))
打印("字典: " + 转字符串(字典))
打印()

打印("--- 2. 条件判断 ---")
变量 分数 = 85
如果 分数 >= 90 {
    打印("优秀！")
} 否则如果 分数 >= 80 {
    打印("良好！")
} 否则如果 分数 >= 60 {
    打印("及格")
} 否则 {
    打印("不及格")
}
打印()

打印("--- 3. 循环 ---")
变量 求和 = 0
遍历 i 在 范围(1, 11) {
    求和 += i
}
打印("1到10的和: " + 转字符串(求和))

变量 倒计时 = 5
当 倒计时 > 0 {
    打印("倒计时: " + 转字符串(倒计时))
    倒计时 -= 1
}
打印("发射！")
打印()

打印("--- 4. 函数 ---")
函数 阶乘(n) {
    如果 n <= 1 {
        返回 1
    }
    返回 n * 阶乘(n - 1)
}
打印("5的阶乘: " + 转字符串(阶乘(5)))

函数 斐波那契(n) {
    如果 n <= 0 {
        返回 0
    }
    如果 n == 1 {
        返回 1
    }
    返回 斐波那契(n - 1) + 斐波那契(n - 2)
}
打印("斐波那契(10): " + 转字符串(斐波那契(10)))

函数 问候(名字, 前缀) {
    返回 前缀 + "，" + 名字 + "！"
}
打印(问候("鸣言", "你好"))
打印(问候("世界", "嗨"))
打印()

打印("--- 5. 列表操作 ---")
变量 数字列表 = [5, 3, 8, 1, 9, 2, 7]
打印("原列表: " + 转字符串(数字列表))
打印("排序: " + 转字符串(排序(数字列表)))
打印("反转: " + 转字符串(反转(数字列表)))
打印("最大值: " + 转字符串(最大值(数字列表)))
打印("最小值: " + 转字符串(最小值(数字列表)))
打印("长度: " + 转字符串(长度(数字列表)))

变量 平方列表 = []
遍历 x 在 数字列表 {
    追加(平方列表, x * x)
}
打印("平方: " + 转字符串(平方列表))
打印()

打印("--- 6. 字符串操作 ---")
变量 文本 = "鸣言是一门中文编程语言"
打印("原文: " + 文本)
打印("长度: " + 转字符串(长度(文本)))
打印("包含'中文': " + 转字符串(包含(文本, "中文")))
打印("替换: " + 替换(文本, "中文", "全中文"))
打印()

打印("--- 7. 类与对象 ---")
类 动物 {
    函数 初始化(名字, 年龄) {
        这个.名字 = 名字
        这个.年龄 = 年龄
    }
    函数 介绍() {
        打印("我叫" + 这个.名字 + "，今年" + 转字符串(这个.年龄) + "岁")
    }
    函数 叫声() {
        打印("...")
    }
}

类 猫 继承 动物 {
    函数 叫声() {
        打印("喵喵喵~")
    }
}

类 狗 继承 动物 {
    函数 叫声() {
        打印("汪汪汪！")
    }
}

变量 小猫 = 新 猫("小花", 2)
变量 小狗 = 新 狗("旺财", 3)

小猫.介绍()
小猫.叫声()
小狗.介绍()
小狗.叫声()
打印()

打印("--- 8. 异常处理 ---")
尝试 {
    变量 结果 = 10 / 0
} 捕获 错误 {
    打印("捕获到错误: " + 错误)
}
打印()

打印("--- 9. 高级功能 ---")
变量 三元结果 = 5 > 3 ? "五大于三" : "五不大于三"
打印("三元表达式: " + 三元结果)

变量 数字 = [1, 2, 3, 4, 5]
变量 偶数 = 过滤(函数(x) { 返回 x % 2 == 0 }, 数字)
打印("偶数: " + 转字符串(偶数))

变量 平方 = 映射(函数(x) { 返回 x * x }, 数字)
打印("平方: " + 转字符串(平方))

变量 总和 = 归约(函数(a, b) { 返回 a + b }, 数字, 0)
打印("总和: " + 转字符串(总和))
打印()

打印("=== 示例结束 ===")
